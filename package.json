{
  "name": "paperward-edge",
  "version": "0.0.1",
  "description": "Paperward edge layer — Cloudflare Worker fronting publisher hostnames; WBA detection + x402 paywall + origin forwarding.",
  "license": "Apache-2.0",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "wrangler dev --env dev",
    "test": "vitest run --workspace vitest.workspace.ts",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "test:e2e": "tsx test/e2e/run.ts",
    "typecheck": "wrangler types && tsc --noEmit",
    "format": "biome format --write",
    "format:check": "biome format",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "check": "biome check",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "provision-tenant": "tsx bin/provision-tenant.ts"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "toucan-js": "^4.0.0",
    "ulid": "^2.3.0",
    "web-bot-auth": "0.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20260101.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "viem": "^2.48.8",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.0.0",
    "wrangler": "^3.80.0"
  }
}
